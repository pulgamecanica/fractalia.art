{
  "name": "react-starter-kit-for-appwrite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "wasm:build": "cd fractal-engine && wasm-pack build --target web --release",
    "wasm:dev": "cd fractal-engine && wasm-pack build --target web --dev",
